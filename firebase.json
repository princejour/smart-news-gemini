{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "README.md",
      ".github/**",
      ".git/**",
      ".nojekyll",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
